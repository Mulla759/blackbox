# Vapi AI add-on configuration for BLACKBOX.
# Copy this file to .env.local and fill in the real values.

# Private Vapi API key. Keep server-side only.
VAPI_API_KEY=your_vapi_private_api_key_here

# Vapi assistant UUID.
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Vapi phone-number UUID, not the visible +1 phone number.
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# Optional default destination for the home-page button.
# If omitted, the page shows a phone-number input.
NEXT_PUBLIC_BLACKBOX_HOME_VAPI_PHONE=+1XXXXXXXXXX
BLACKBOX_HOME_VAPI_PHONE=+1XXXXXXXXXX
